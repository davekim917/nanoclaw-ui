{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.tsx",
    "src/**/*.ts",
    "src/styles"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/api",
    "src/app-shell.ts",
    "src/main.ts",
    "src/router.ts",
    "src/urlpattern.d.ts",
    "src/components/auth-form.ts",
    "src/components/chat-input.ts",
    "src/components/chat-message.ts",
    "src/components/group-picker.ts",
    "src/components/run-history.ts",
    "src/components/sidebar-nav.ts",
    "src/components/skill-card.ts",
    "src/components/streaming-text.ts",
    "src/components/workflow-card.ts",
    "src/components/workflow-detail.ts",
    "src/pages/chat-page.ts",
    "src/pages/sessions-page.ts",
    "src/pages/skills-page.ts",
    "src/pages/workflows-page.ts",
    "src/state",
    "src/theme",
    "src/utils"
  ]
}
